@@ -3,12 +3,30 @@
 #include <darling/emulation/common/base.h>
 #include <darling/emulation/conversion/errno.h>
 #include <darling/emulation/linux_premigration/linux-syscalls/linux.h>
+#include <darling/emulation/linux_premigration/vchroot_expand.h>
+#include <darling/emulation/common/bsdthread/per_thread_wd.h>
 
 long sys_chroot(const char* path)
 {
 	int ret;
+	struct vchroot_expand_args vc;
 
-	ret = LINUX_SYSCALL(__NR_chroot, path);
+	// Translate the prefix-relative path to its host-side absolute path
+	// before passing it to Linux. Without this, callers (notably Apple's
+	// sshd privsep child doing chroot("/var/empty")) end up calling
+	// Linux chroot on a path that doesn't exist on the host rootfs, and
+	// even if it did, the prefix's path translation would no longer
+	// reach into the host's prefix tree from inside the new chroot.
+	vc.flags = VCHROOT_FOLLOW;
+	vc.dfd = get_perthread_wd();
+
+	strcpy(vc.path, path);
+
+	ret = vchroot_expand(&vc);
+	if (ret < 0)
+		return errno_linux_to_bsd(ret);
+
+	ret = LINUX_SYSCALL(__NR_chroot, vc.path);
 	if (ret < 0)
 		ret = errno_linux_to_bsd(ret);
 
