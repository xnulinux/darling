diff --git a/openssh/sshd.c b/openssh/sshd.c
index 1cafcbc..8a4d5c8 100644
--- a/openssh/sshd.c
+++ b/openssh/sshd.c
@@ -1691,7 +1691,16 @@ main(int ac, char **av)
 	);
 
 	/* Store privilege separation user for later use if required. */
-	privsep_chroot = use_privsep && (getuid() == 0 || geteuid() == 0);
+	/*
+	 * Darling: disable privsep chroot. Linux's chroot() inside the
+	 * Darling prefix puts the process in a subtree that the prefix's
+	 * vchroot_expand path translation can no longer reach, so the
+	 * very next call (chdir("/")) fails ENOENT and the privsep child
+	 * dies before any kex packet is processed. This loses the chroot
+	 * isolation but keeps the fork/pipe privilege separation intact.
+	 */
+	privsep_chroot = 0;
+	(void)use_privsep;
 	if ((privsep_pw = getpwnam(SSH_PRIVSEP_USER)) == NULL) {
 		if (privsep_chroot || options.kerberos_authentication)
 			fatal("Privilege separation user %s does not exist",
