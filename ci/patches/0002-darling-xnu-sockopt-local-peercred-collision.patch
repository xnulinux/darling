@@ -9,15 +9,24 @@ extern void* memset(void*, int, __SIZE_TYPE__);
 
 int sockopt_bsd_to_linux(int* level, int* optname, void** optval, void* optbuf)
 {
-	/* TCP_NODELAY and LOCAL_PEERCRED both have values of 1 */
