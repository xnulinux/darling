+	 * and leaving the caller's optlen unmodified at its initial value.
+	 *
+	 * sshd's check_ip_options() relies on getsockopt(IPPROTO_IP, IP_OPTIONS)
+	 * to update optlen to 0 for sockets without IP options; with the stub,
+	 * optlen stayed at sizeof(buf)=200, which sshd interpreted as a source
+	 * routing attack and fatal()'d every connection.
+	 *
+	 * Removing the stub: AF_LOCAL callers that genuinely want LOCAL_PEERCRED
+	 * will now hit Linux's getsockopt(IPPROTO_IP, IP_OPTIONS) on a unix
+	 * socket and get EOPNOTSUPP, which is the right early-return signal for
+	 * code that handles "this OS doesn't support LOCAL_PEERCRED."
+	 */
 	if (*level == BSD_SOL_SOCKET)
 	{
 		*level = LINUX_SOL_SOCKET;
