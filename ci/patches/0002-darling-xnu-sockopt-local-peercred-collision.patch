+// Linux ABI constants used to disambiguate the LOCAL_PEERCRED/IP_OPTIONS
+// (level=0, optname=1) collision via the actual socket family.
+#define LINUX_SOL_SOCKET_LOCAL  1
+#define LINUX_SO_DOMAIN         39
+#define LINUX_AF_UNIX           1
+#define LINUX_IPPROTO_IP_LOCAL  0
+#define LINUX_IP_OPTIONS_LOCAL  4
+
 long sys_getsockopt(int fd, int level, int optname, void* optval, int* optlen)
 {
 	int ret, linux_level, linux_optname;
-	
+
+	// On Apple, LOCAL_PEERCRED (SOL_LOCAL=0, opt=1) and IP_OPTIONS
+	// (IPPROTO_IP=0, opt=1) have the same (level, optname) pair. The
+	// translator has a stub for LOCAL_PEERCRED that fakes a euid-0
+	// xucred and skips the syscall, which is what shellspawn/launchd
+	// expect on AF_UNIX sockets — but it also swallows IP_OPTIONS
+	// queries on AF_INET, breaking sshd (which interprets the unset
+	// optlen as IP options present and fatals).
+	//
+	// Bypass the stub for AF_INET by checking the socket's actual
+	// domain via Linux's SO_DOMAIN and going straight to the kernel's
+	// IP_OPTIONS path. AF_UNIX falls through to the translator stub.
+	if (level == 0 && optname == 1 && optval != NULL && optlen != NULL) {
+		int domain = 0;
+		int domain_len = sizeof(domain);
+		long dret;
+
+#ifdef __NR_socketcall
+		dret = LINUX_SYSCALL(__NR_socketcall, LINUX_SYS_GETSOCKOPT,
+			((long[6]) { fd, LINUX_SOL_SOCKET_LOCAL, LINUX_SO_DOMAIN,
+				&domain, &domain_len, 0 }));
+#else
+		dret = LINUX_SYSCALL(__NR_getsockopt, fd,
+			LINUX_SOL_SOCKET_LOCAL, LINUX_SO_DOMAIN,
+			&domain, &domain_len);
+#endif
+
+		if (dret == 0 && domain != LINUX_AF_UNIX) {
+			// Real IP socket: call Linux's IP_OPTIONS directly,
+			// bypassing the LOCAL_PEERCRED stub in the translator.
+#ifdef __NR_socketcall
+			ret = LINUX_SYSCALL(__NR_socketcall, LINUX_SYS_GETSOCKOPT,
+				((long[6]) { fd, LINUX_IPPROTO_IP_LOCAL,
+					LINUX_IP_OPTIONS_LOCAL, optval, optlen, 0 }));
+#else
+			ret = LINUX_SYSCALL(__NR_getsockopt, fd,
+				LINUX_IPPROTO_IP_LOCAL, LINUX_IP_OPTIONS_LOCAL,
+				optval, optlen);
+#endif
+			if (ret < 0)
+				ret = errno_linux_to_bsd(ret);
+			return ret;
+		}
+		// dret != 0 (SO_DOMAIN failed) or domain == AF_UNIX:
+		// fall through, let the translator handle as LOCAL_PEERCRED.
+	}
+
 	linux_level = level;
 	linux_optname = optname;
-	
+
 	ret = sockopt_bsd_to_linux(&linux_level, &linux_optname, NULL, optval);
-	
+
 	if (ret != 0 || !linux_optname)
 		return ret;
 
